# DocManager CA Desktop - Environment Variables Template
# Copy this file to .env and fill in your values

# Backend Configuration
CA_DATABASE_URL=sqlite:///ca_desktop.db
SECRET_KEY=your-secret-key-here-min-32-chars
CA_SECRET_KEY=your-secret-key-here-min-32-chars

# Server Configuration
HOST=127.0.0.1
PORT=8443

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Email Service (Optional - for client invites)
RESEND_API_KEY=your-resend-api-key-here

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.xlsx,.xls,.doc,.docx

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ca_desktop.log

# Frontend Configuration (for Vite)
VITE_API_URL=http://localhost:8443/api/v1

# Production Deployment
# For Vercel/Railway, set these in the platform's environment variables UI
# Do NOT commit actual values to git
