# License Server Configuration
DATABASE_URL=postgresql://license_admin:your_password_here@localhost:5432/license_server
SECRET_KEY=your_secret_key_here_min_32_characters
ENVIRONMENT=development

# PostgreSQL
POSTGRES_PASSWORD=your_postgres_password_here

# RSA Keys (auto-generated on first run)
PRIVATE_KEY_PATH=keys/private_key.pem
PUBLIC_KEY_PATH=keys/public_key.pem

# Server Config
HOST=0.0.0.0
PORT=8000
WS_PORT=8001

# License Config
DEFAULT_LICENSE_DAYS=30
MAX_LICENSE_DAYS=365

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/license_server.log
