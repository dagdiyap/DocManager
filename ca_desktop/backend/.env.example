# CA Desktop Backend Configuration
DATABASE_URL=sqlite:///./ca_desktop.db
SECRET_KEY=your_secret_key_here_min_32_characters
ENVIRONMENT=development

# License Server
LICENSE_SERVER_URL=http://localhost:8000
LICENSE_SERVER_WS_URL=ws://localhost:8001

# Public Key (embedded or path)
PUBLIC_KEY_PATH=keys/public_key.pem

# Document Storage
DOCUMENTS_ROOT=documents/
SHARED_FILES_ROOT=shared_files/

# Server Config
HOST=0.0.0.0
PORT=8443
ENABLE_HTTPS=true

# File Download
TOKEN_EXPIRY_SECONDS=600
MAX_FILE_SIZE_MB=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ca_desktop.log

# Device Fingerprint
DEVICE_ID_FILE=.device_id

# Support Mode
SUPPORT_MODE_ENABLED=false
SUPPORT_SESSION_TIMEOUT_MINUTES=30
